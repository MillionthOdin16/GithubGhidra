{
  "name": "ghidra-apk-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Ghidra and APK analysis on GitHub",
  "main": "mcp_server.py",
  "scripts": {
    "start": "python3 mcp_server.py",
    "test": "python3 -m pytest tests/",
    "validate": "python3 validate_mcp.py",
    "lint": "flake8 mcp_server.py",
    "format": "black mcp_server.py && isort mcp_server.py",
    "docker:build": "docker build -t ghidra-mcp-server .",
    "docker:run": "docker run -p 8000:8000 ghidra-mcp-server",
    "deploy:staging": "gh workflow run deploy.yml -f environment=staging",
    "deploy:production": "gh workflow run deploy.yml -f environment=production"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MillionthOdin16/GithubGhidra.git"
  },
  "keywords": [
    "mcp",
    "ghidra", 
    "apk",
    "reverse-engineering",
    "security-analysis",
    "github",
    "model-context-protocol"
  ],
  "author": "GitHub MCP Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MillionthOdin16/GithubGhidra/issues"
  },
  "homepage": "https://github.com/MillionthOdin16/GithubGhidra#readme"
}